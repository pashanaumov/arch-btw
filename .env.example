# Neon Postgres (get from Neon console → Connection Details)
DATABASE_URL=                    # pooled connection (for app)
DATABASE_URL_UNPOOLED=           # direct connection (for drizzle-kit migrations)

# Better Auth
BETTER_AUTH_SECRET=              # openssl rand -base64 32
BETTER_AUTH_URL=                 # https://your-app.vercel.app  (must match OAuth callback)

# GitHub OAuth (github.com/settings/developers → New OAuth App)
# Callback URL: https://your-app.vercel.app/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# LLM — set exactly ONE of these (Gemini takes priority if multiple set)
GEMINI_API_KEY=                  # aistudio.google.com
ANTHROPIC_API_KEY=               # console.anthropic.com
OPENAI_API_KEY=                  # platform.openai.com
